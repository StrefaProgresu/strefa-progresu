# =============================================================================
#  STREFA PROGRESU — zmienne środowiskowe
# -----------------------------------------------------------------------------
#  Skopiuj ten plik do ".env.local" i uzupełnij prawdziwymi wartościami.
#  .env.local NIE trafia do gita — to bezpieczne miejsce na klucze.
#
#  Na Vercel te same zmienne dodaj w:
#    Project -> Settings -> Environment Variables
# =============================================================================

# --- STRIPE ------------------------------------------------------------------
# Panel Stripe -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Podpis webhooka — otrzymasz go przy tworzeniu webhooka
# (Stripe -> Developers -> Webhooks) lub z komendy `stripe listen` przy testach lokalnych.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- RESEND (wysyłka maili) --------------------------------------------------
# Panel Resend -> API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Adres nadawcy. Do testów możesz zostawić onboarding@resend.dev.
# Docelowo: zweryfikuj własną domenę w Resend i wpisz np. "STREFA PROGRESU <zakup@twojadomena.pl>"
EMAIL_FROM=STREFA PROGRESU <onboarding@resend.dev>

# --- BEZPIECZEŃSTWO POBIERANIA -----------------------------------------------
# Dowolny długi, losowy ciąg. Służy do podpisywania linków do pobierania PDF.
# Wygeneruj np. komendą:  openssl rand -hex 32
DOWNLOAD_SECRET=zmien-mnie-na-dlugi-losowy-ciag-znakow

# --- ADRES STRONY ------------------------------------------------------------
# Lokalnie: http://localhost:3000
# Na produkcji wpisz swój pełny adres, np. https://strefa-progresu.vercel.app
# albo własną domenę. Bez tego linki w mailach mogą być błędne.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
